<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:background="#FFE7EDE9"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingEnd="18dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <TextView android:textColor="#FF141C18"
        android:id="@+id/label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NEXT PRAYER"
        android:textSize="9sp" />

    <TextView android:textColor="#FF141C18"
        android:id="@+id/next_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Dhuhr"
        android:textSize="30sp"
        android:textStyle="bold"
        android:maxLines="1" />

    <TextView android:textColor="#FF141C18"
        android:id="@+id/next_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="in 2h 14m"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1" />

    <TextView android:textColor="#FF141C18"
        android:id="@+id/next_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3:45 PM"
        android:textSize="14sp"
        android:maxLines="1" />

    <!-- flex spacer via empty TextView with weight -->
    <TextView android:textColor="#FF141C18"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="" />

    <FrameLayout
        android:id="@+id/then_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:textColor="#FF141C18"
            android:id="@+id/then_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THEN"
            android:textSize="8sp" />

        <TextView android:textColor="#FF141C18"
            android:id="@+id/following_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Asr"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView android:textColor="#FF141C18"
            android:id="@+id/following_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6:12 PM"
            android:textSize="12sp"
            android:maxLines="1" />
    </LinearLayout>

</LinearLayout>
