<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:background="#FFE7EDE9"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/left"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView android:textColor="#FF141C18"
            android:id="@+id/left_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEXT PRAYER"
            android:textSize="9sp" />

        <TextView android:textColor="#FF141C18"
            android:id="@+id/left_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Asr"
            android:textSize="34sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView android:textColor="#FF141C18"
            android:id="@+id/left_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3:45 PM"
            android:textSize="14sp"
            android:maxLines="1" />

        <TextView android:textColor="#FF141C18"
            android:id="@+id/left_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="in 2h 14m"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/vline"
        android:layout_width="1dp"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/right"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout android:id="@+id/row0"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark0" android:layout_width="2dp" android:layout_height="9dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="8dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name0" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Fajr" android:textSize="13sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time0" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="5:23" android:textSize="12sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div01" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row1"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark1" android:layout_width="2dp" android:layout_height="9dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="8dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Dhuhr" android:textSize="13sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time1" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="12:30" android:textSize="12sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div12" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row2"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark2" android:layout_width="2dp" android:layout_height="9dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="8dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Asr" android:textSize="13sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time2" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="15:45" android:textSize="12sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div23" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row3"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark3" android:layout_width="2dp" android:layout_height="9dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="8dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Maghrib" android:textSize="13sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time3" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="18:20" android:textSize="12sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div34" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row4"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark4" android:layout_width="2dp" android:layout_height="9dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="8dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name4" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Isha" android:textSize="13sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time4" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="20:15" android:textSize="12sp"
                android:maxLines="1" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
