<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:background="#FFE7EDE9"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Hero: deep green, horizontal split -->
    <LinearLayout
        android:id="@+id/hero"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:background="#FF003C33"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Left: next prayer info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:orientation="vertical"
            android:gravity="bottom">

            <TextView android:textColor="#FFBFF0DD"
                android:id="@+id/hero_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"
                android:text="NEXT PRAYER"
                android:textSize="9sp" />

            <TextView android:textColor="#FFFFFFFF"
                android:id="@+id/hero_next_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asr"
                android:textSize="32sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView android:textColor="#FFBFF0DD"
                android:id="@+id/hero_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="in 2h 14m · 3:45 PM"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Right: location + dates -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="bottom|end">

            <TextView android:textColor="#FFBFF0DD"
                android:id="@+id/hero_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="Karachi"
                android:textSize="10sp"
                android:maxLines="1" />

            <TextView android:textColor="#FFBFF0DD"
                android:id="@+id/hero_date_greg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="Saturday, 7 Jun"
                android:textSize="11sp"
                android:maxLines="1" />

            <TextView android:textColor="#FFBFF0DD"
                android:id="@+id/hero_date_hijri"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="11 Dhu al-Hijjah 1446"
                android:textSize="10sp"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/band_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp" />

    <!-- Body: full prayer schedule -->
    <LinearLayout
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout android:id="@+id/row0"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark0" android:layout_width="3dp" android:layout_height="12dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="10dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name0" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Fajr" android:textSize="14sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time0" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="5:23" android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div01" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row1"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark1" android:layout_width="3dp" android:layout_height="12dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="10dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Dhuhr" android:textSize="14sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time1" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="12:30" android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div12" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row2"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark2" android:layout_width="3dp" android:layout_height="12dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="10dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Asr" android:textSize="14sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time2" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="15:45" android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div23" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row3"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark3" android:layout_width="3dp" android:layout_height="12dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="10dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Maghrib" android:textSize="14sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time3" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="18:20" android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

        <FrameLayout android:id="@+id/div34" android:layout_width="match_parent" android:layout_height="1dp" />

        <LinearLayout android:id="@+id/row4"
            android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center_vertical">
            <FrameLayout android:id="@+id/mark4" android:layout_width="3dp" android:layout_height="12dp"
                android:background="@drawable/widget_mark_muted_light"
                android:layout_marginEnd="10dp" />
            <TextView android:textColor="#FF141C18" android:id="@+id/name4" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Isha" android:textSize="14sp"
                android:textStyle="bold" android:maxLines="1" />
            <TextView android:textColor="#FF141C18" android:id="@+id/time4" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="20:15" android:textSize="13sp"
                android:maxLines="1" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
